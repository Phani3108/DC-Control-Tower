# =========================================================================
# DC Control Tower — environment variables
# Copy to .env.local for Next.js and export in your shell for FastAPI.
# =========================================================================

# --- Anthropic (FastAPI side; never exposed to browser) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_OPUS_MODEL=claude-opus-4-6
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_SANDBOX_URL=
ANTHROPIC_TIMEOUT_MS=

# --- Optional alternate AI providers ---
OPENAI_BASE_URL=https://api.openai.com
OPENAI_SANDBOX_URL=
OPENAI_API_KEY=
OPENAI_TIMEOUT_MS=

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_SANDBOX_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_TIMEOUT_MS=

# --- Backend wiring ---
# URL the Next.js proxy hits (internal Railway URL in prod, localhost in dev)
FASTAPI_URL=http://localhost:8000

# Public URL of this Next.js app (used for FastAPI CORS allowlist)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# When true, the Next.js proxy short-circuits to canned JSON fixtures.
# Flip to true for reliable interview demos without hitting Anthropic.
MOCK_AGENTS=false

# --- Optional live data sources (Next.js side; proxied to avoid CORS) ---
EMBER_API_KEY=
EIA_API_KEY=
EMBER_BASE_URL=https://api.ember-energy.org
EIA_BASE_URL=https://api.eia.gov

# --- M7 connector providers (Next.js server route side) ---
# Set URLs to turn on live ingestion for M7 power signals.
M7_UTILITY_TELEMETRY_URL=
M7_MARKET_PRICE_URL=
M7_UTILITY_TELEMETRY_SANDBOX_URL=
M7_MARKET_PRICE_SANDBOX_URL=

# Optional global timeout in milliseconds (default: 2500)
M7_CONNECTOR_TIMEOUT_MS=

# Utility provider auth (optional)
M7_UTILITY_TELEMETRY_BEARER_TOKEN=
M7_UTILITY_TELEMETRY_API_KEY=
M7_UTILITY_TELEMETRY_API_KEY_HEADER=x-api-key
M7_UTILITY_TELEMETRY_BASIC_USERNAME=
M7_UTILITY_TELEMETRY_BASIC_PASSWORD=
M7_UTILITY_TELEMETRY_AUTH_HEADER_NAME=
M7_UTILITY_TELEMETRY_AUTH_HEADER_VALUE=
M7_UTILITY_TELEMETRY_TIMEOUT_MS=

# Market provider auth (optional)
M7_MARKET_PRICE_BEARER_TOKEN=
M7_MARKET_PRICE_API_KEY=
M7_MARKET_PRICE_API_KEY_HEADER=x-api-key
M7_MARKET_PRICE_BASIC_USERNAME=
M7_MARKET_PRICE_BASIC_PASSWORD=
M7_MARKET_PRICE_AUTH_HEADER_NAME=
M7_MARKET_PRICE_AUTH_HEADER_VALUE=
M7_MARKET_PRICE_TIMEOUT_MS=

# --- Optional database connectors (for Integration Center tests) ---
POSTGRES_URL=
POSTGRES_TIMEOUT_MS=

MYSQL_URL=
MYSQL_TIMEOUT_MS=

REDIS_URL=
REDIS_TIMEOUT_MS=

MONGODB_URI=
MONGODB_TIMEOUT_MS=

# --- Disk cache for preset replays (FastAPI side) ---
CACHE_DIR=./src/data/agent-cache
